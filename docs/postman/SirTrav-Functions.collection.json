{
  "info": {
    "_postman_id": "f7af41f8-9ec1-4bba-b2fd-e81bd116117c",
    "name": "SirTrav Functions",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Contract-locked function checks for SirTrav A2A Studio."
  },
  "item": [
    {
      "name": "healthcheck",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/healthcheck",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "healthcheck"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('status 200', () => pm.response.to.have.status(200));",
              "const j = pm.response.json();",
              "pm.test('json body', () => !!j);",
              "pm.test('has status', () => typeof j.status === 'string');"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "start-pipeline",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{bearerToken}}",
            "disabled": true
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\"projectId\":\"{{projectId}}\",\"mode\":\"dry-run\"}"
        },
        "url": {
          "raw": "{{baseUrl}}/start-pipeline",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "start-pipeline"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('status is expected', () => pm.expect([200,202,401]).to.include(pm.response.code));",
              "pm.test('json parse', () => { pm.response.json(); });"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "progress POST",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\"projectId\":\"{{projectId}}\",\"runId\":\"{{runId}}\",\"step\":\"smoke\",\"status\":\"running\"}"
        },
        "url": {
