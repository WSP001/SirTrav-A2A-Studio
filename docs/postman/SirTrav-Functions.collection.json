          ],
          "path": [
            "progress"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('status 200', () => pm.response.to.have.status(200));",
              "pm.test('json parse', () => { pm.response.json(); });"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "progress GET",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/progress?projectId={{projectId}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "progress"
          ],
          "query": [
            {
              "key": "projectId",
              "value": "{{projectId}}"
            }
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('status 200', () => pm.response.to.have.status(200));",
              "pm.test('json parse', () => { pm.response.json(); });"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "publish-x (dry)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\"text\":\"SirTrav dry-run smoke\",\"projectId\":\"{{projectId}}\",\"runId\":\"{{runId}}\",\"dryRun\":{{dryRun}}}"
        },
        "url": {
          "raw": "{{baseUrl}}/publish-x",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "publish-x"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('status 200', () => pm.response.to.have.status(200));",
              "const j = pm.response.json();",
              "pm.test('json body', () => !!j);",
              "if (j.success === true) {",
              "  pm.test('success requires tweet id', () => pm.expect(j.tweetId || j.id || j.xId).to.exist);",
              "}",
              "if (j.disabled === true) {",
              "  pm.test('disabled requires reason', () => pm.expect(j.reason || j.error || j.note).to.exist);",
              "}"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "publish-linkedin (dry)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\"projectId\":\"{{projectId}}\",\"runId\":\"{{runId}}\",\"videoUrl\":\"https://sirtrav-a2a-studio.netlify.app/test-assets/sample.mp4\",\"title\":\"SirTrav dry-run smoke\",\"description\":\"SirTrav dry-run smoke (LinkedIn)\",\"visibility\":\"PUBLIC\",\"dryRun\":{{dryRun}}}"
        },
        "url": {
          "raw": "{{baseUrl}}/publish-linkedin",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "publish-linkedin"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('status 200', () => pm.response.to.have.status(200));",
              "const j = pm.response.json();",
              "pm.test('json body', () => !!j);",
              "if (j.success === true) {",
              "  pm.test('success requires LinkedIn id', () => pm.expect(j.linkedinId || j.urn || j.ugcPostUrn || j.postId).to.exist);",
              "}",
              "if (j.disabled === true) {",
              "  pm.test('disabled requires reason', () => pm.expect(j.reason || j.error || j.note).to.exist);",
              "}"
            ],
            "type": "text/javascript"
          }
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "https://sirtrav-a2a-studio.netlify.app/.netlify/functions"
    },
    {
      "key": "projectId",
      "value": "sirtrav-test"
    },
    {
      "key": "runId",
      "value": "manual-{{$timestamp}}"
    },
    {
      "key": "dryRun",
      "value": "true"
    },
    {
      "key": "bearerToken",
      "value": ""
    }
  ]
}
