# SirTrav A2A Studio - Environment Variables
# Copy this file to .env and fill in your values
# v3.0.0 - CC-017 Comprehensive Env Template (2026-02-28)
#
# SCOPE KEY:
#   [NETLIFY] = Set in Netlify Dashboard > Site > Environment Variables
#   [LOCAL]   = Set in local .env for `netlify dev`
#   [AUTO]    = Auto-injected by Netlify at build/runtime — do not set manually

# =============================================================================
# CORE AI SERVICES — Required for video production pipeline
# =============================================================================

# [NETLIFY+LOCAL] OpenAI — Director, Writer, Curator agents (GPT-4 Vision)
OPENAI_API_KEY=

# [NETLIFY+LOCAL] ElevenLabs — Voice Agent (AI narration)
ELEVENLABS_API_KEY=

# [NETLIFY+LOCAL] Suno — Composer Agent (music generation, manual workflow)
# Note: No public API yet — we use prompt templates. Key is for future use.
SUNO_API_KEY=
SUNO_API_URL=https://api.suno.ai/v1

# [NETLIFY+LOCAL] OpenRouter — Fallback AI routing (optional)
OPENROUTER_API_KEY=

# =============================================================================
# SOCIAL MEDIA PUBLISHING — MVP: X/Twitter + YouTube
# =============================================================================

# [NETLIFY] X/Twitter OAuth 1.0a (User Context — required for posting)
# Get from: https://developer.x.com/en/portal/dashboard
# IMPORTANT: All 4 keys must come from the SAME developer app
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_SECRET=

# [NETLIFY] YouTube Data API v3
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REFRESH_TOKEN=

# [NETLIFY] LinkedIn Marketing API v2 (optional)
# Get from: https://www.linkedin.com/developers/apps
# Request "Share on LinkedIn" product for w_member_social scope
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_PERSON_URN=
LINKEDIN_ORGANIZATION_ID=

# [NETLIFY] TikTok Content Posting API (optional)
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_ACCESS_TOKEN=
TIKTOK_REFRESH_TOKEN=

# [NETLIFY] Instagram Graph API (optional, requires Facebook Business)
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_BUSINESS_ID=

# =============================================================================
# VIDEO RENDERING — Remotion Lambda (optional, uses placeholder locally)
# =============================================================================

# [NETLIFY] Remotion Lambda function for cloud rendering
REMOTION_FUNCTION_NAME=
REMOTION_SERVE_URL=
REMOTION_REGION=us-east-1

# [NETLIFY] FFmpeg Service URL (alternative to Remotion)
FFMPEG_SERVICE_URL=

# =============================================================================
# STORAGE
# =============================================================================

# [AUTO] Netlify Blobs — auto-injected by Netlify runtime
# NETLIFY_BLOBS_CONTEXT=  (do not set manually)

# [LOCAL] Netlify identity for local blob access via `netlify dev`
NETLIFY_SITE_ID=
NETLIFY_API_TOKEN=
NETLIFY_AUTH_TOKEN=

# [NETLIFY] AWS S3 — alternative storage backend (optional)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET=
S3_PUBLIC_BASE_URL=
STORAGE_BACKEND=netlify_blobs

# =============================================================================
# SECURITY & UTILITIES
# =============================================================================

# [NETLIFY+LOCAL] API authentication secret for start-pipeline
API_SECRET=

# [NETLIFY+LOCAL] Issue intake endpoint secret
ISSUE_INTAKE_SECRET=

# [NETLIFY+LOCAL] MCP endpoint token
MCP_SECRET_TOKEN=

# [NETLIFY+LOCAL] Share link signing secret
SHARE_SECRET=

# [NETLIFY] Bitly short URLs (optional)
BITLY_ACCESS_TOKEN=

# =============================================================================
# OBSERVABILITY
# =============================================================================

# [NETLIFY] Enable distributed tracing
TRACING_ENABLED=false

# =============================================================================
# DEVELOPMENT — Local only
# =============================================================================

# [LOCAL] Vault path for local development
VAULT_PATH=

# [AUTO] Netlify build context vars (auto-injected, listed for reference)
# URL=                    # Site URL
# BUILD_ID=               # Build identifier
# COMMIT_REF=             # Git commit SHA
# CONTEXT=                # deploy context (production/deploy-preview/branch-deploy)
# BRANCH=                 # Git branch name
# NETLIFY_SITE_DOMAIN=    # Site domain
# NETLIFY_DEV=            # "true" when running netlify dev
